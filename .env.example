# Pinterest Factory — Environment Variables
# Copy to .env and fill in your values

# ── Notion (required for Tab 4) ──────────────────────────────────────────────
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Groq API (required for AI generation) ──────────────────────────────────
# Get your API key at: https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GROQ_MODEL=llama-3.1-8b-instant

# ── Hugging Face (optional for tailored image generation) ───────────────────
HF_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_IMAGE_MODEL=stabilityai/stable-diffusion-xl-base-1.0

# ── Pinterest API (optional for scheduling) ─────────────────────────────────
PINTEREST_ACCESS_TOKEN=pin_xxxxxxxxxxxxxxxxx
PINTEREST_BOARD_ID=xxxxxxxxxxxxxxxx
